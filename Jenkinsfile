pipeline { agent any triggers { githubPush() // 🔥 webhook trigger } environment { APP_NAME = "my-app" } stages { stage('Checkout Code') { steps { echo "📥 Cloning repository..." git url: 'https://github.com/devopsghazali/jenkins_project_demo.git', branch: 'main' } } stage('Build') { steps { echo "🔨 Building application..." sh 'echo Build started' sh 'mkdir -p build && echo "Hello from build" > build/output.txt' } } stage('Test') { steps { echo "🧪 Running tests..." sh 'echo Tests passed' } } stage('Archive Artifacts') { steps { echo "📦 Saving artifacts..." archiveArtifacts artifacts: 'build/**', fingerprint: true } } } post { success { echo "✅ SUCCESS: Build completed successfully!" } failure { echo "❌ FAILURE: Build failed!" } always { echo "📌 Pipeline finished." } } }
